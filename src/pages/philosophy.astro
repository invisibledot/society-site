---
import Layout from "../layouts/Layout.astro";
import Header from "../components/ui/Header.astro";

---

<Layout title="Adelphosophy | Agora" description="A spiritual and philosophical doctrine of universal knowledge.">
  
  <article class="pt-32 pb-24 px-6 bg-olive-50 text-olive-900 antialiased">
    <div class="max-w-3xl mx-auto space-y-16">
      
      <Header>
        <span slot="surtitle">
          A spiritual foundation
        </span>
        <fragment slot="header">
          The Adelphosophical Society
        </fragment>
        <fragment slot="subtitle">
          A spiritual and philosophical doctrine of universal knowledge.
        </fragment>
      </Header>

      <div class="space-y-18">
        
    <section class="text-center space-y-4">
        <h2 class="text-6xl font-bold text-olive-950 tracking-tight">COMING SOON</h2>
    </section>

    <footer class="pt-12">
        <a href="/manifesto" class="text-olive-600 hover:text-amber-700 font-bold transition flex items-center gap-2 group">
          <span class="group-hover:-translate-x-1 transition-transform">←</span> Back to the Manifesto
        </a>
    </footer>

    </div>
  </article>

</Layout>