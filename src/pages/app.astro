---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Social Network | The Society App" description="The last social app you'll ever need. Built for real-world coordination.">
  
  <section class="pt-32 pb-20 px-6 bg-zinc-950 text-zinc-100">
    <div class="max-w-4xl mx-auto text-center space-y-8">
      <div class="inline-block px-3 py-1 rounded-full border border-zinc-700 text-xs font-mono uppercase tracking-widest text-zinc-400">
        Project: Social Network
      </div>
      <h1 class="text-5xl md:text-7xl font-bold tracking-tight">
        The last social app <br/> <span class="text-zinc-500">you’ll ever need.</span>
      </h1>
      <p class="text-xl text-zinc-400 max-w-2xl mx-auto">
        No algorithm. No infinite scroll. No data mining. Just a digital bridge to your local physical community.
      </p>
    </div>
  </section>

  <section class="py-24 px-6 bg-zinc-900">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12">
      
      <div class="p-8 rounded-2xl bg-zinc-950 border border-white/5 space-y-6">
        <h2 class="text-2xl font-semibold">For Members</h2>
        <p class="text-zinc-400 leading-relaxed">
          The app functions as a <strong>Local Bulletin Board</strong>. Find where the Society is meeting, RSVP for events, and see announcements from your Chapter Leader. It opens, gives you the info you need, and encourages you to close it.
        </p>
        <ul class="space-y-3 text-sm text-zinc-300">
          <li class="flex items-center gap-2">✔ Neighborhood Event Map</li>
          <li class="flex items-center gap-2">✔ RSVP & Check-in</li>
          <li class="flex items-center gap-2">✔ Peer-to-Peer “Analog Exchanges”</li>
        </ul>
      </div>

      <div class="p-8 rounded-2xl bg-zinc-800/50 border border-white/10 space-y-6">
        <h2 class="text-2xl font-semibold">For Chapter Leaders</h2>
        <p class="text-zinc-400 leading-relaxed">
          A powerful <strong>Coordination Hub</strong>. Manage your local cell, track attendance, and sync with Central Leadership. It’s the logistics layer that keeps the Society moving forward without the noise of traditional social media.
        </p>
        <ul class="space-y-3 text-sm text-zinc-300">
          <li class="flex items-center gap-2">✔ Member Management</li>
          <li class="flex items-center gap-2">✔ Direct Sync with Central HQ</li>
          <li class="flex items-center gap-2">✔ Leader-to-Leader Strategy Channels</li>
        </ul>
      </div>

    </div>
  </section>

  <section class="py-24 px-6 text-center">
    <h2 class="text-3xl font-bold mb-6 text-white">Join the Beta</h2>
    <p class="text-zinc-400 mb-8 max-w-lg mx-auto">We are rolling out “Social Network” chapter by chapter to ensure quality over quantity.</p>
    <a href="/#cta" class="inline-block bg-white text-black px-10 py-4 rounded-lg font-bold hover:bg-zinc-200 transition">
      Apply for Access
    </a>
  </section>

</Layout>