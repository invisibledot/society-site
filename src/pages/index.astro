---
import Layout from "../layouts/Layout.astro";
import ContactForm from "../components/ContactForm.astro";
---

<Layout 
  title="The Society - The antidote to the algorithm" 
  description="A private society for those choosing depth over distraction."
>
  <section
    id="hero"
    class="relative min-h-screen flex items-center justify-center px-6 text-zinc-100 antialiased
           bg-[url('/hero-bg.jpg')] bg-cover bg-center"
  >
    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black/80"></div>

    <div class="relative max-w-3xl text-center space-y-6 fade-up">
      <h1 class="text-5xl md:text-6xl font-bold tracking-tight">
        The antidote to the algorithm.
      </h1>
      <p class="text-lg md:text-xl text-zinc-200">
        A private society for those choosing depth over distraction. Reclaim your attention through in-person community and analog experiences.
      </p>
      <a
        href="#features"
        class="inline-block rounded-lg bg-white text-black px-6 py-3 font-medium hover:bg-zinc-200 transition"
      >
        Join the Movement
      </a>
    </div>
  </section>

  <section id="about" class="px-6 py-24 bg-zinc-900 text-zinc-100 scroll-mt-16">
    <div class="max-w-3xl mx-auto space-y-6">
        <h2 class="text-3xl font-semibold">Life is happening elsewhere.</h2>
        <p class="text-zinc-400">
          We spend an average of seven hours a day behind glass. The Society exists to reclaim that time. We are a decentralized collective of thinkers, makers, and explorers who believe the most important things in life happen in high-definition, face-to-face. No feeds, no notifications—just presence.
        </p>
    </div>
  </section>

  <section id="features" class="px-6 py-24 bg-zinc-950 text-zinc-100 scroll-mt-16">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-semibold text-center mb-12">
        What you get
      </h2>

      <div class="grid gap-8 md:grid-cols-3">
        {[
          { title: "Phone-Free Gatherings", desc: "Weekly dinners, hikes, and workshops where all digital devices are checked at the door." },
          { title: "The Analog Library", desc: "Access to our physical archive of curated prints, vinyl, and literature—exclusive to members." },
          { title: "Local Chapters", desc: "Find your “Cell.” Small, local groups dedicated to shared hobbies like woodworking, philosophy, or gardening." },
        ].map(feature => (
          <div class="rounded-xl bg-zinc-900 p-6 border border-white/5">
            <h3 class="font-medium mb-2 text-white">{feature.title}</h3>
            <p class="text-sm text-zinc-400">
              {feature.desc}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

<section id="cta" class="px-6 py-32 bg-zinc-900 text-center text-zinc-100 scroll-mt-16">
    <div class="max-w-2xl mx-auto space-y-6">
      <h2 class="text-4xl font-semibold mb-8">Ready to disconnect?</h2>
            <p class="text-lg md:text-xl text-zinc-200">
        Membership is currently by invitation and application only. Tell us why you’re ready to trade your screen time for real time.
      </p>
      <ContactForm /> </div>
</section>
</Layout>