---
---
<form id="contact-form" class="max-w-md mx-auto space-y-4 text-left">
  <div>
    <label for="email" class="block text-sm font-medium mb-1">Email</label>
    <input type="email" name="email" id="email" required 
      class="w-full bg-zinc-800 border border-white/10 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-white/20" />
  </div>
  <div>
    <label for="message" class="block text-sm font-medium mb-1">Message</label>
    <textarea name="message" id="message" required rows="4"
      class="w-full bg-zinc-800 border border-white/10 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-white/20"></textarea>
  </div>
  <button type="submit" class="w-full bg-white text-black font-medium py-3 rounded-lg hover:bg-zinc-200 transition">
    Send Message
  </button>
  <p id="response-msg" class="text-sm text-center mt-4 hidden"></p>
</form>

<script>
  import { actions } from 'astro:actions';

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const msg = document.getElementById('response-msg');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    
    // Call the action
    const { data, error } = await actions.contact(formData);

    if (msg) {
      msg.classList.remove('hidden');
      if (error) {
        msg.textContent = "Something went wrong. Please try again.";
        msg.className = "text-red-400 text-sm text-center mt-4";
      } else {
        msg.textContent = data.message;
        msg.className = "text-green-400 text-sm text-center mt-4";
        form.reset();
      }
    }
  });
</script>