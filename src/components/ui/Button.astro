---
// src/components/ui/Button.astro
const { href, type = "button", variant = "primary" } = Astro.props;

// Tailwind 4 styles using your @theme variables
const baseStyles = "px-10 py-4 rounded-full font-bold transition-all active:scale-95 text-sm uppercase tracking-widest inline-block text-center cursor-pointer";
const variants = {
  primary: "bg-brand-dark text-white hover:bg-brand-accent shadow-md",
  outline: "border-2 border-brand-dark text-brand-dark hover:bg-brand-dark hover:text-white",
  fullWidth: "w-full bg-brand-dark text-white hover:bg-brand-accent"
};

const classes = `${baseStyles} ${variants[variant]}`;
---

{href ? (
  <a href={href} class={classes}>
    <slot />
  </a>
) : (
  <button type={type} class={classes}>
    <slot />
  </button>
)}